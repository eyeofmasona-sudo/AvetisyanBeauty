# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="password"
# JWT_SECRET: required in production. The server refuses to start without it.
JWT_SECRET="your_jwt_secret_here"
# SITE_URL / VITE_SITE_URL: public origin used for canonical URLs, hreflang,
# robots.txt and sitemap.xml. Set this to the real production domain.
SITE_URL="https://example.com"
VITE_SITE_URL="https://example.com"
# VITE_GA_MEASUREMENT_ID: Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX).
# Leave unset to disable GA loading entirely.
VITE_GA_MEASUREMENT_ID=""
# VITE_META_PIXEL_ID: Meta/Facebook Pixel ID. Leave unset to disable Meta Pixel loading.
VITE_META_PIXEL_ID=""

# --- AI Messaging Assistant (Instagram Direct & WhatsApp auto-reply) ---
# Master switch. The webhooks below always respond 200 to Meta, but do nothing
# unless this is exactly "true". Keep unset/false until all credentials below
# are verified working.
AI_ASSISTANT_ENABLED="false"
# Shared secret from your Meta App > Settings > Basic, used to verify that
# incoming webhook requests really come from Meta (HMAC SHA-256 signature).
META_APP_SECRET=""
# Arbitrary string you choose yourself and enter in the Meta webhook
# subscription form (Instagram Messaging product) to confirm the callback URL.
META_VERIFY_TOKEN=""
# Same idea as META_VERIFY_TOKEN, but for the WhatsApp Business webhook
# subscription (Meta allows using separate tokens per product).
WHATSAPP_VERIFY_TOKEN=""
# WhatsApp Cloud API: Phone Number ID and a permanent access token generated
# for a System User in Meta Business Manager (Settings > WhatsApp > API Setup).
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
# Instagram Messaging API: the Instagram Business Account ID (linked to a
# Facebook Page) and a Page Access Token with the instagram_manage_messages
# permission (Meta for Developers > your App > Instagram > API setup).
INSTAGRAM_ACCOUNT_ID=""
INSTAGRAM_PAGE_ACCESS_TOKEN=""
