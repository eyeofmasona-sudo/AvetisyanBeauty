# ============================================================================
# Avetisyan Beauty Clinic — environment variables
# ============================================================================
# Copy this file to `.env` (server-side) and fill in the values.
# VITE_*-prefixed variables are exposed to the browser via Vite.

# --- Supabase (replaces Firebase) -------------------------------------------
# Get these from: Supabase Dashboard → Project Settings → API
#   - Project URL           → SUPABASE_URL  + VITE_SUPABASE_URL (same value)
#   - anon public key       → VITE_SUPABASE_ANON_KEY
#   - service_role secret   → SUPABASE_SERVICE_ROLE_KEY  ⚠️ NEVER expose to browser
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR-ANON-PUBLIC-KEY"

# Run supabase/migration.sql in the Supabase SQL Editor before starting the
# server — it creates the `site`, `ai_knowledge`, `ai_threads`, `ai_messages`
# tables, the `uploads` storage bucket, RLS policies, and Realtime publication.

# --- Gemini (AI) ------------------------------------------------------------
# Required for Gemini AI API calls (text/image/video/TTS generation, AI assistant).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# --- Admin auth -------------------------------------------------------------
# Username + password for the admin panel login. The server signs a JWT cookie
# (`admin_token`, 12h expiry) on POST /api/auth/login.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="password"
# JWT_SECRET: required in production. The server refuses to start without it.
JWT_SECRET="your_jwt_secret_here"

# --- Site URL ---------------------------------------------------------------
# Public origin used for canonical URLs, hreflang, robots.txt, sitemap.xml.
SITE_URL="https://example.com"
VITE_SITE_URL="https://example.com"

# --- Analytics (optional) ---------------------------------------------------
# VITE_GA_MEASUREMENT_ID: Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX).
VITE_GA_MEASUREMENT_ID=""
# VITE_META_PIXEL_ID: Meta/Facebook Pixel ID.
VITE_META_PIXEL_ID=""

# --- AI Messaging Assistant (Instagram Direct & WhatsApp auto-reply) --------
# Master switch. The webhooks always respond 200 to Meta, but do nothing
# unless this is exactly "true".
AI_ASSISTANT_ENABLED="false"
# Shared secret from your Meta App > Settings > Basic, used to verify that
# incoming webhook requests really come from Meta (HMAC SHA-256 signature).
META_APP_SECRET=""
# Arbitrary string you choose and enter in the Meta webhook subscription form
# (Instagram Messaging product) to confirm the callback URL.
META_VERIFY_TOKEN=""
# Same idea as META_VERIFY_TOKEN, but for the WhatsApp Business webhook.
WHATSAPP_VERIFY_TOKEN=""
# WhatsApp Cloud API: Phone Number ID and a permanent access token generated
# for a System User in Meta Business Manager.
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
# Instagram Messaging API: the Instagram Business Account ID and a Page Access
# Token with the instagram_manage_messages permission.
INSTAGRAM_ACCOUNT_ID=""
INSTAGRAM_PAGE_ACCESS_TOKEN=""
# Optional: pre-seed an Instagram long-lived token at boot (otherwise managed
# via the admin panel's Instagram Connect section).
INSTAGRAM_ACCESS_TOKEN=""

# --- Instagram account token encryption (optional) --------------------------
# APP_SECRET is used to encrypt Instagram access tokens stored in the local
# `instagram_accounts.json` file. If unset, a volatile in-memory key is used
# and tokens will be lost on restart.
APP_SECRET=""
