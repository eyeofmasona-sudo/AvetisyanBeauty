# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="password"
# JWT_SECRET: required in production. The server refuses to start without it.
JWT_SECRET="your_jwt_secret_here"
# SITE_URL / VITE_SITE_URL: public origin used for canonical URLs, hreflang,
# robots.txt and sitemap.xml. Set this to the real production domain.
SITE_URL="https://example.com"
VITE_SITE_URL="https://example.com"
# VITE_GA_MEASUREMENT_ID: Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX).
# Leave unset to disable GA loading entirely.
VITE_GA_MEASUREMENT_ID=""
# VITE_META_PIXEL_ID: Meta/Facebook Pixel ID. Leave unset to disable Meta Pixel loading.
VITE_META_PIXEL_ID=""
