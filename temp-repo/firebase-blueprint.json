{
  "entities": {
    "Admin": {
      "title": "Admin",
      "description": "Administrator of the system",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "Email of the admin"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp of creation"
        }
      },
      "required": ["email", "createdAt"]
    },
    "AIKnowledgeItem": {
      "title": "AI Knowledge Item",
      "description": "Knowledge base item for the AI assistant",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "question": { "type": "string" },
        "answer_hy": { "type": "string" },
        "answer_ru": { "type": "string" },
        "answer_en": { "type": "string" },
        "service_slug": { "type": "string" },
        "is_active": { "type": "boolean" },
        "requires_human_review": { "type": "boolean" },
        "created_at": { "type": "number" },
        "updated_at": { "type": "number" }
      },
      "required": ["category", "question", "answer_en", "is_active", "requires_human_review", "created_at", "updated_at"]
    },
    "AIThread": {
      "title": "AI Thread",
      "description": "A conversation thread between a user and the AI",
      "type": "object",
      "properties": {
        "channel": { "type": "string" },
        "external_thread_id": { "type": "string" },
        "customer_name": { "type": "string" },
        "customer_handle": { "type": "string" },
        "language": { "type": "string" },
        "status": { "type": "string" },
        "assigned_to": { "type": "string" },
        "created_at": { "type": "number" },
        "updated_at": { "type": "number" }
      },
      "required": ["channel", "external_thread_id", "customer_name", "customer_handle", "language", "status", "created_at", "updated_at"]
    },
    "AIMessage": {
      "title": "AI Message",
      "description": "A single message within an AI thread",
      "type": "object",
      "properties": {
        "direction": { "type": "string" },
        "channel": { "type": "string" },
        "original_text": { "type": "string" },
        "detected_language": { "type": "string" },
        "ai_suggested_reply": { "type": "string" },
        "final_reply": { "type": "string" },
        "status": { "type": "string" },
        "confidence": { "type": "number" },
        "requires_human": { "type": "boolean" },
        "created_at": { "type": "number" }
      },
      "required": ["direction", "channel", "original_text", "status", "requires_human", "created_at"]
    },
    "GalleryCase": {
      "title": "Gallery Case",
      "description": "Before and After gallery case",
      "type": "object",
      "properties": {
        "protocol": { "type": "string" },
        "patientDesc": { "type": "string" },
        "category": { "type": "string" },
        "beforeLabel": { "type": "string" },
        "afterLabel": { "type": "string" },
        "beforeImage": { "type": "string" },
        "afterImage": { "type": "string" }
      },
      "required": ["protocol", "patientDesc", "category"]
    }
  },
  "firestore": {
    "admins/{adminId}": {
      "schema": { "$ref": "Admin" },
      "description": "List of administrators"
    },
    "ai_knowledge/{itemId}": {
      "schema": { "$ref": "AIKnowledgeItem" },
      "description": "Knowledge base items"
    },
    "ai_threads/{threadId}": {
      "schema": { "$ref": "AIThread" },
      "description": "Conversations"
    },
    "ai_threads/{threadId}/messages/{messageId}": {
      "schema": { "$ref": "AIMessage" },
      "description": "Messages inside a conversation"
    },
    "gallery_cases/{caseId}": {
      "schema": { "$ref": "GalleryCase" },
      "description": "Gallery before/after cases"
    }
  }
}
