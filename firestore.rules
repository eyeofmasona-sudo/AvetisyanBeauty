rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isBootstrappedAdmin() {
      return isSignedIn() && request.auth.token.email_verified == true && request.auth.token.email == 'eyeofmasona@gmail.com';
    }

    function isAdmin() {
      return isBootstrappedAdmin() || (isSignedIn() && request.auth.token.email_verified == true && exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // AI Knowledge
    function isValidAIKnowledgeItem(data) {
      return data.keys().hasAll(['category', 'question', 'answer_en', 'is_active', 'requires_human_review', 'created_at', 'updated_at']) &&
             data.category is string && data.category.size() <= 100 &&
             data.question is string && data.question.size() <= 1000 &&
             data.answer_en is string && data.answer_en.size() <= 5000 &&
             data.is_active is bool &&
             data.requires_human_review is bool &&
             data.created_at is number &&
             data.updated_at is number;
    }

    match /ai_knowledge/{itemId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(itemId) && isValidAIKnowledgeItem(incoming()) && incoming().created_at == request.time.toMillis() && incoming().updated_at == request.time.toMillis();
      allow update: if isAdmin() && isValidId(itemId) && isValidAIKnowledgeItem(incoming()) && incoming().updated_at == request.time.toMillis() && incoming().created_at == existing().created_at;
      allow delete: if isAdmin() && isValidId(itemId);
    }

    // AI Thread
    function isValidAIThread(data) {
      return data.keys().hasAll(['channel', 'external_thread_id', 'customer_name', 'customer_handle', 'language', 'status', 'created_at', 'updated_at']) &&
             data.channel is string && data.channel.size() <= 50 &&
             data.external_thread_id is string && data.external_thread_id.size() <= 128 &&
             data.customer_name is string && data.customer_name.size() <= 128 &&
             data.customer_handle is string && data.customer_handle.size() <= 128 &&
             data.language is string && data.language.size() <= 10 &&
             data.status is string && data.status.size() <= 50 &&
             data.created_at is number &&
             data.updated_at is number;
    }

    match /ai_threads/{threadId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidId(threadId) && isValidAIThread(incoming()) && incoming().created_at == request.time.toMillis() && incoming().updated_at == request.time.toMillis();
      allow update: if isAdmin() && isValidId(threadId) && isValidAIThread(incoming()) && incoming().updated_at == request.time.toMillis() && incoming().created_at == existing().created_at;
      allow delete: if isAdmin() && isValidId(threadId);

      // AI Messages (Subcollection)
      function isValidAIMessage(data) {
        return data.keys().hasAll(['direction', 'channel', 'original_text', 'status', 'requires_human', 'created_at']) &&
               data.direction is string && data.direction.size() <= 20 &&
               data.channel is string && data.channel.size() <= 50 &&
               data.original_text is string && data.original_text.size() <= 10000 &&
               data.status is string && data.status.size() <= 50 &&
               data.requires_human is bool &&
               data.created_at is number;
      }

      match /messages/{messageId} {
        allow read: if isAdmin();
        allow create: if isAdmin() && isValidId(threadId) && isValidId(messageId) && isValidAIMessage(incoming()) && incoming().created_at == request.time.toMillis();
        allow update: if isAdmin() && isValidId(threadId) && isValidId(messageId) && isValidAIMessage(incoming()) && incoming().created_at == existing().created_at;
        allow delete: if isAdmin() && isValidId(threadId) && isValidId(messageId);
      }
    }

    // Gallery Cases
    function isValidGalleryCase(data) {
       return data.keys().hasAll(['protocol', 'patientDesc', 'category']) &&
              data.protocol is string && data.protocol.size() <= 128 &&
              data.patientDesc is string && data.patientDesc.size() <= 500 &&
              data.category is string && data.category.size() <= 50;
    }

    match /gallery_cases/{caseId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(caseId) && isValidGalleryCase(incoming());
      allow update: if isAdmin() && isValidId(caseId) && isValidGalleryCase(incoming());
      allow delete: if isAdmin() && isValidId(caseId);
    }
    
    // Site data (content, gallery)
    match /site/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Instagram Accounts (encrypted tokens)
    match /instagram_accounts/{docId} {
      allow read, write: if isAdmin();
    }

    // Admins
    function isValidAdmin(data) {
      return data.keys().hasAll(['email', 'createdAt']) && data.keys().size() == 2 &&
             data.email is string && data.email.size() <= 128 &&
             data.createdAt is number;
    }
    
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidId(adminId) && isValidAdmin(incoming()) && incoming().createdAt == request.time.toMillis();
      allow update: if false; // Immutable
      allow delete: if isAdmin() && isValidId(adminId);
    }
  }
}
