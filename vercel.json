{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!api/|assets/|videos/|images/|favicon|manifest|robots|sitemap|og-image).*)",
      "destination": "/index.html"
    }
  ]
}
