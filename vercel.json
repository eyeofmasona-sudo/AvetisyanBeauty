{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://REPLACE_WITH_BACKEND_URL/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://REPLACE_WITH_BACKEND_URL/uploads/:path*"
    },
    {
      "source": "/((?!assets/|videos/|images/|favicon|manifest|robots|sitemap|og-image).*)",
      "destination": "/index.html"
    }
  ]
}
